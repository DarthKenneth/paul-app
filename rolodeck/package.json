{
  "name": "rolodeck",
  "version": "1.13.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "icons": "node scripts/generate-icons.js",
    "test": "jest --no-cache",
    "release": "eas build --platform all --profile production --non-interactive --auto-submit",
    "build:ios": "eas build --platform ios --profile production --non-interactive",
    "build:android": "eas build --platform android --profile production --non-interactive",
    "submit": "eas submit --platform all --profile production --non-interactive --latest",
    "preview": "eas build --platform all --profile preview --non-interactive"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!@react-native-async-storage)"
    ],
    "moduleFileExtensions": [
      "js",
      "json"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.2.3",
    "@expo-google-fonts/dm-serif-display": "^0.2.3",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/stack": "^6.3.29",
    "expo": "~55.0.13",
    "expo-calendar": "~55.0.14",
    "expo-crypto": "~55.0.14",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.6",
    "expo-sharing": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-calendars": "^1.1314.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@jest/globals": "^29.7.0",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "^55.0.16",
    "jest": "^29.7.0",
    "sharp": "^0.33.0"
  },
  "private": true
}
