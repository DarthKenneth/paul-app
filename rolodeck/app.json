{
  "expo": {
    "name": "Callout CRM",
    "slug": "rolodeck",
    "scheme": "rolodeck",
    "version": "1.4.4",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./store-assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF0E0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "plugins": [
      [
        "expo-calendar",
        {
          "calendarPermission": "Callout uses your calendar to sync service due dates for your customers."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Callout uses your photo library to attach photos to service notes.",
          "cameraPermission": "Callout uses your camera to take photos for service notes."
        }
      ],
      "expo-font",
      "expo-sharing",
      "expo-web-browser",
      "expo-secure-store",
      "expo-updates"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ardingate.rolodeck",
      "icon": {
        "light": "./store-assets/icons/icon.png",
        "dark": "./store-assets/icons/icon-dark.png",
        "tinted": "./store-assets/icons/icon-dark.png"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./store-assets/icons/adaptive-icon-fg.png",
        "monochromeImage": "./store-assets/icons/adaptive-icon-monochrome.png",
        "backgroundColor": "#FDF0E0"
      },
      "package": "com.ardingate.rolodeck",
      "permissions": [
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./store-assets/icons/icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "117e475a-df12-4791-a8bf-5d761b4c526c"
      }
    },
    "owner": "ardingate-studios-llc"
  }
}
