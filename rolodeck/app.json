{
  "expo": {
    "name": "Rolodeck",
    "slug": "rolodeck",
    "scheme": "rolodeck",
    "version": "0.18.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./store-assets/icons/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C6ECEA"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-calendar",
        {
          "calendarPermission": "Rolodeck uses your calendar to sync service due dates for your customers."
        }
      ],
      "expo-font",
      "expo-sharing",
      "expo-web-browser"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ardingate.rolodeck",
      "icon": {
        "any": "./store-assets/icons/icon.png",
        "dark": "./store-assets/icons/icon-dark.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./store-assets/icons/adaptive-icon-fg.png",
        "backgroundColor": "#C6ECEA"
      },
      "package": "com.ardingate.rolodeck",
      "permissions": [
        "READ_CALENDAR",
        "WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./store-assets/icons/icon.png"
    }
  }
}
