# ---------------------------------------------------------------------------
# EAS / Expo CLI
# Required for CI/CD (GitHub Actions) and for running `npm run release` locally
# Get your token: expo.dev/accounts/[username]/settings/access-tokens
# ---------------------------------------------------------------------------
EXPO_TOKEN=your_expo_access_token_here

# ---------------------------------------------------------------------------
# Apple (store submission)
# These are set as EAS project secrets, NOT in this file:
#   eas secret:create --scope project --name APPLE_ID --value "you@email.com"
#   eas secret:create --scope project --name ASC_APP_ID --value "1234567890"
#   eas secret:create --scope project --name APPLE_TEAM_ID --value "XXXXXXXXXX"
#
# APPLE_ID      = your Apple Developer account email
# ASC_APP_ID    = numeric App ID in App Store Connect (App Information > Apple ID)
# APPLE_TEAM_ID = 10-char team ID at developer.apple.com/account (Membership section)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Android (store submission)
# Upload your Google Play service account JSON to EAS via:
#   eas credentials --platform android
# Then select "Set up Google Service Account Key for submitting"
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Square (user-configured at runtime — no build-time secret needed)
# Square OAuth credentials are entered by the end user in app Settings.
# They are stored locally on-device via AsyncStorage. No server required.
# ---------------------------------------------------------------------------
