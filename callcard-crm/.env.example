# =============================================================================
# .env.example - Rolodeck environment variable reference
# Version: 1.3
# Last Updated: 2026-04-29
#
# PROJECT:      Rolodeck (project v1.5.3)
# Copyright © 2026 ArdinGate Studios LLC. All rights reserved.
#
# USAGE:
#   Copy this file to .env and fill in real values.
#   .env is gitignored — never commit real credentials.
#
#   Variables prefixed EXPO_PUBLIC_ are inlined into the JS bundle at build
#   time (Expo SDK 49+) and accessible via process.env.EXPO_PUBLIC_*.
#   These are NOT secret — restrict keys at the provider (domain/bundle-ID
#   allowlist) rather than relying on .env for confidentiality.
#
# CHANGE LOG:
# v1.0  2026-04-09  Claude  Initial scaffold
# v1.1  2026-04-10  Claude  Added EXPO_PUBLIC_GEOAPIFY_API_KEY for address
#                            autocomplete (moved out of placesConfig.js hardcode)
# v1.3  2026-04-29  Claude  Added EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID for Android
#                            Google Drive cross-device sync
# v1.2  2026-04-14  Claude  Added Square credentials and Sentry DSN entries;
#                            updated Square section comment (now env-var driven)
# =============================================================================

# ---------------------------------------------------------------------------
# EAS / Expo CLI
# Required for CI/CD (GitHub Actions) and for running `npm run release` locally
# Get your token: expo.dev/accounts/[username]/settings/access-tokens
# ---------------------------------------------------------------------------
EXPO_TOKEN=your_expo_access_token_here

# ---------------------------------------------------------------------------
# Apple (store submission)
# These are set as EAS project secrets, NOT in this file:
#   eas secret:create --scope project --name APPLE_ID --value "you@email.com"
#   eas secret:create --scope project --name ASC_APP_ID --value "1234567890"
#   eas secret:create --scope project --name APPLE_TEAM_ID --value "XXXXXXXXXX"
#
# APPLE_ID      = your Apple Developer account email
# ASC_APP_ID    = numeric App ID in App Store Connect (App Information > Apple ID)
# APPLE_TEAM_ID = 10-char team ID at developer.apple.com/account (Membership section)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Android (store submission)
# Upload your Google Play service account JSON to EAS via:
#   eas credentials --platform android
# Then select "Set up Google Service Account Key for submitting"
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Square (build-time config — set in .env, never commit real values)
# These are NOT secret keys; they identify your app to Square's OAuth flow.
# Restrict access by bundle ID in the Square Developer Dashboard.
#
# EXPO_PUBLIC_SQUARE_CLIENT_ID     — Application ID from developer.squareup.com
#                                    → Your App → Credentials tab
# EXPO_PUBLIC_SQUARE_LOCATION_ID   — Location ID from developer.squareup.com
#                                    → Locations. Used for invoices + orders.
#                                    TODO: fetch from /v2/locations after auth
#                                    to support any merchant automatically.
# EXPO_PUBLIC_SQUARE_ENVIRONMENT   — 'sandbox' (default) or 'production'.
#                                    Sandbox and production require separate
#                                    Client ID values.
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SQUARE_CLIENT_ID=
EXPO_PUBLIC_SQUARE_LOCATION_ID=
EXPO_PUBLIC_SQUARE_ENVIRONMENT=sandbox

# ---------------------------------------------------------------------------
# Sentry crash reporting (optional)
# Get your DSN from sentry.io → Project Settings → Client Keys (DSN).
# Leave empty to disable Sentry — the app initialises it only when DSN is set.
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SENTRY_DSN=

# ---------------------------------------------------------------------------
# Geoapify address autocomplete
# Free tier (3k requests/day): https://myprojects.geoapify.com
# Inlined into bundle at build time via EXPO_PUBLIC_ prefix. Restrict the key
# to your bundle ID in the Geoapify dashboard for defense-in-depth.
# Leave empty to disable autocomplete — manual address entry still works.
# ---------------------------------------------------------------------------
EXPO_PUBLIC_GEOAPIFY_API_KEY=

# ---------------------------------------------------------------------------
# Google Drive (Android cross-device sync)
# This is a PUBLIC OAuth client ID — not a secret. It will be bundled into
# the app. The client must be type "Android" in Google Cloud Console
# (Web-application clients reject custom URI schemes). The Cloud Console
# verifies the app's package name + signing certificate SHA-1 at sign-in
# time, so you need ONE OAuth client per (package, signing key) pair.
#
# Setup (one-time, already done as of v2.0.0):
#   1. console.cloud.google.com → APIs & Services → Library → Enable "Google Drive API"
#   2. Auth Platform → Clients → Create client
#      Application type: Android
#      Package name:     com.ardingate.rolodeck
#      SHA-1 fingerprint: from Play Console → App integrity → App signing key
#      (For internal/EAS-direct builds: also register the upload key SHA-1
#       as a SECOND client; eas.json's `preview` profile points at it.)
#   3. Copy the Client IDs into eas.json (production = Play key client,
#      preview = upload key client). eas.json overrides this .env at build time.
#   4. For local `expo start` development, set this to the upload-key client
#      ID (same one used in eas.json's preview profile) so dev OAuth works.
# ---------------------------------------------------------------------------
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
